# ── LLM provider (optional — defaults to free local Ollama) ───────────────────
# auto | ollama | openai | openrouter
LLM_PROVIDER=auto

# ── Ollama (default free/local path) ──────────────────────────────────────────
# Install: https://ollama.com — then run: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── OpenAI (optional paid provider) ─────────────────────────────────────────
# When set, auto mode prefers OpenAI unless LLM_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── OpenRouter (optional hosted free/paid models) ─────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ── Model override (optional, applies to active provider) ───────────────────────
MODEL_NAME=
TEMPERATURE=0.5

# ── LangSmith tracing (optional) ───────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ask-kernel

# ── Smart home — Home Assistant (optional) ─────────────────────────────────────
# Get a long-lived token from: HA → Profile → Long-Lived Access Tokens
HOME_ASSISTANT_URL=http://192.168.1.100:8123
HOME_ASSISTANT_TOKEN=eyJ...

# ── A.S.K. backend URL (used by Streamlit) ─────────────────────────────────────
BACKEND_URL=http://localhost:8000
